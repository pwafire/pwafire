{
  "hosting": {
    "site": "console-pwafire",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/mock/webauthn/register",
        "destination": "/mock/webauthn/register.json"
      },
      {
        "source": "/mock/webauthn/signin",
        "destination": "/mock/webauthn/signin.json"
      }
    ],
    "headers": [
      {
        "source": "**/*",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/mock/**/*.json",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
